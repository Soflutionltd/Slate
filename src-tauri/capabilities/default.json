{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Default capabilities granted to the Alto desktop main window.",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:window:default",
		"core:webview:default",
		"core:event:default",
		"dialog:default",
		"dialog:allow-open",
		"dialog:allow-save",
		"fs:default",
		"fs:allow-read-file",
		"fs:allow-write-file",
		"updater:default"
	]
}
