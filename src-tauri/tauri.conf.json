{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
	"productName": "Slate",
	"version": "0.1.0",
	"identifier": "com.soflution.slate",
	"build": {
		"frontendDist": "./frontend-dist",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "",
		"beforeBuildCommand": "cd src-tauri && mkdir -p binaries && touch binaries/alto-mcp-aarch64-apple-darwin && cargo build --release --bin alto-mcp && cp target/release/alto-mcp binaries/alto-mcp-aarch64-apple-darwin"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "Slate",
				"url": "index.html",
				"width": 1440,
				"height": 920,
				"minWidth": 800,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null,
			"dangerousDisableAssetCspModification": true
		}
	},
	"bundle": {
		"active": true,
		"targets": ["app", "dmg"],
		"resources": ["libpdfium.dylib"],
		"externalBin": ["binaries/alto-mcp"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"category": "Productivity",
		"shortDescription": "Slate — Fast local PDF reader",
		"longDescription": "Slate is a local PDF reader and editor for opening, searching, zooming, editing and annotating PDF files without an Adobe subscription.",
		"copyright": "© 2026 Soflution LTD",
		"createUpdaterArtifacts": false,
		"fileAssociations": [
			{
				"ext": ["pdf"],
				"name": "PDF Document",
				"description": "Portable Document Format",
				"role": "Viewer",
				"rank": "Default",
				"mimeType": "application/pdf"
			}
		],
		"macOS": {
			"minimumSystemVersion": "11.0",
			"signingIdentity": "Developer ID Application: Soflution ltd (TB8CC687M3)"
		}
	}
}
